{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://intu.dev/schema/channel.schema.json",
  "title": "intu Channel Configuration",
  "description": "Schema for intu channel.yaml files. Defines a message processing channel with a source listener, optional validator/transformer, and one or more destinations.",
  "type": "object",
  "required": ["id", "enabled", "listener"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier for this channel"
    },
    "enabled": {
      "type": "boolean",
      "description": "Whether this channel is active"
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of what this channel does"
    },
    "profiles": {
      "type": "array",
      "items": { "type": "string" },
      "description": "If specified, channel is only loaded when the active profile matches one of these values"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for filtering and grouping channels"
    },
    "group": {
      "type": "string",
      "description": "Logical group this channel belongs to"
    },
    "priority": {
      "type": "string",
      "description": "Processing priority for this channel"
    },
    "data_types": {
      "type": "object",
      "description": "Inbound and outbound data type declarations for automatic parsing",
      "properties": {
        "inbound": {
          "type": "string",
          "enum": ["raw", "json", "xml", "csv", "hl7v2", "hl7v3", "ccda", "fhir_r4", "x12", "binary"],
          "description": "Inbound message format for automatic parsing"
        },
        "outbound": {
          "type": "string",
          "enum": ["raw", "json", "xml", "csv", "hl7v2", "hl7v3", "ccda", "fhir_r4", "x12", "binary"],
          "description": "Outbound message format for automatic serialization"
        },
        "inbound_properties": {
          "type": "object",
          "description": "Additional properties for the inbound parser (e.g., CSV delimiter)"
        },
        "outbound_properties": {
          "type": "object",
          "description": "Additional properties for the outbound serializer"
        }
      }
    },
    "listener": {
      "type": "object",
      "description": "Source/listener configuration for this channel",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["http", "tcp", "file", "kafka", "database", "sftp", "channel", "email", "dicom", "soap", "fhir", "fhir_poll", "fhir_subscription", "ihe"],
          "description": "Listener type"
        },
        "http": {
          "type": "object",
          "description": "HTTP listener configuration",
          "properties": {
            "port": { "type": "integer", "description": "Port to listen on" },
            "path": { "type": "string", "description": "URL path to listen on" },
            "methods": {
              "type": "array",
              "items": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "description": "Allowed HTTP methods"
            },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["port"]
        },
        "tcp": {
          "type": "object",
          "description": "TCP/MLLP listener configuration",
          "properties": {
            "port": { "type": "integer", "description": "Port to listen on" },
            "mode": { "type": "string", "enum": ["raw", "mllp"], "description": "TCP mode (raw or MLLP for HL7v2)" },
            "max_connections": { "type": "integer", "description": "Maximum concurrent connections" },
            "timeout_ms": { "type": "integer", "description": "Connection timeout in milliseconds" },
            "tls": { "$ref": "#/definitions/tls" },
            "ack": {
              "type": "object",
              "properties": {
                "auto": { "type": "boolean", "description": "Auto-generate ACK responses" },
                "success_code": { "type": "string", "description": "ACK code on success (e.g., AA)" },
                "error_code": { "type": "string", "description": "ACK code on error (e.g., AE)" },
                "reject_code": { "type": "string", "description": "ACK code on reject (e.g., AR)" }
              }
            },
            "response": {
              "type": "object",
              "properties": {
                "on_success": { "type": "string" },
                "on_error": { "type": "string" },
                "on_filter_drop": { "type": "string" },
                "wait_for_destinations": { "type": "boolean" }
              }
            }
          },
          "required": ["port"]
        },
        "file": {
          "type": "object",
          "description": "File poller configuration",
          "properties": {
            "scheme": { "type": "string", "enum": ["local", "ftp", "s3", "smb"], "description": "File system scheme" },
            "directory": { "type": "string", "description": "Directory to poll" },
            "file_pattern": { "type": "string", "description": "Glob pattern for file matching" },
            "poll_interval": { "type": "string", "description": "Polling interval (e.g., 10s, 1m)" },
            "move_to": { "type": "string", "description": "Move processed files to this directory" },
            "error_dir": { "type": "string", "description": "Move failed files to this directory" },
            "sort_by": { "type": "string", "enum": ["name", "date", "size"] },
            "ftp": {
              "type": "object",
              "properties": {
                "host": { "type": "string" },
                "port": { "type": "integer" },
                "auth": { "$ref": "#/definitions/auth" }
              }
            },
            "s3": {
              "type": "object",
              "properties": {
                "bucket": { "type": "string" },
                "region": { "type": "string" },
                "prefix": { "type": "string" },
                "auth": { "$ref": "#/definitions/auth" }
              }
            },
            "smb": {
              "type": "object",
              "properties": {
                "host": { "type": "string" },
                "auth": { "$ref": "#/definitions/auth" }
              }
            }
          }
        },
        "kafka": {
          "type": "object",
          "description": "Kafka consumer configuration",
          "properties": {
            "brokers": { "type": "array", "items": { "type": "string" }, "description": "Kafka broker addresses" },
            "topic": { "type": "string", "description": "Kafka topic to consume from" },
            "group_id": { "type": "string", "description": "Consumer group ID" },
            "offset": { "type": "string", "enum": ["earliest", "latest"], "description": "Starting offset" },
            "auth": { "$ref": "#/definitions/auth" },
            "tls": { "$ref": "#/definitions/tls" }
          },
          "required": ["topic"]
        },
        "database": {
          "type": "object",
          "description": "Database poller configuration",
          "properties": {
            "driver": { "type": "string", "enum": ["postgres", "mysql", "mssql", "sqlite"] },
            "dsn": { "type": "string", "description": "Database connection string" },
            "poll_interval": { "type": "string" },
            "query": { "type": "string", "description": "SQL query to poll for new records" },
            "post_process_statement": { "type": "string", "description": "SQL to run after reading records" },
            "tls": { "$ref": "#/definitions/tls" }
          },
          "required": ["driver", "dsn"]
        },
        "sftp": {
          "type": "object",
          "description": "SFTP file poller configuration",
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "integer", "default": 22 },
            "poll_interval": { "type": "string" },
            "directory": { "type": "string" },
            "file_pattern": { "type": "string" },
            "move_to": { "type": "string" },
            "error_dir": { "type": "string" },
            "auth": { "$ref": "#/definitions/auth" },
            "sort_by": { "type": "string", "enum": ["name", "date", "size"] }
          },
          "required": ["host"]
        },
        "channel": {
          "type": "object",
          "description": "Channel chaining source",
          "properties": {
            "source_channel_id": { "type": "string", "description": "Channel ID to receive messages from" }
          },
          "required": ["source_channel_id"]
        },
        "email": {
          "type": "object",
          "description": "Email inbox poller (IMAP/POP3)",
          "properties": {
            "protocol": { "type": "string", "enum": ["imap", "pop3"] },
            "host": { "type": "string" },
            "port": { "type": "integer" },
            "poll_interval": { "type": "string" },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" },
            "folder": { "type": "string", "default": "INBOX" },
            "filter": { "type": "string" },
            "read_attachments": { "type": "boolean" },
            "delete_after_read": { "type": "boolean" }
          },
          "required": ["host"]
        },
        "dicom": {
          "type": "object",
          "description": "DICOM C-STORE SCP listener",
          "properties": {
            "port": { "type": "integer" },
            "ae_title": { "type": "string", "description": "Application Entity title" },
            "calling_ae_titles": { "type": "array", "items": { "type": "string" }, "description": "Allowed calling AE titles" },
            "tls": { "$ref": "#/definitions/tls" }
          },
          "required": ["port"]
        },
        "soap": {
          "type": "object",
          "description": "SOAP web service endpoint",
          "properties": {
            "port": { "type": "integer" },
            "wsdl_path": { "type": "string" },
            "service_name": { "type": "string" },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["port"]
        },
        "fhir": {
          "type": "object",
          "description": "FHIR REST endpoint or subscription listener",
          "properties": {
            "port": { "type": "integer" },
            "base_path": { "type": "string", "default": "/fhir" },
            "version": { "type": "string", "enum": ["R4", "STU3"] },
            "resources": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Accepted FHIR resource types. CapabilityStatement is derived from this list. Unlisted types are rejected with 404. When omitted, all types are accepted."
            },
            "subscription_type": { "type": "string", "enum": ["rest-hook", "websocket"] },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["port"]
        },
        "fhir_poll": {
          "type": "object",
          "description": "FHIR HTTP polling source. Periodically GETs an external FHIR server with optional date range (e.g. _lastUpdated, date). Many FHIR resources support date-range search params.",
          "properties": {
            "base_url": { "type": "string", "description": "FHIR server base URL (e.g. https://fhir.example.com/fhir/r4)" },
            "poll_interval": { "type": "string", "description": "Polling interval (e.g. 30s, 5m)", "default": "1m" },
            "poll_range": { "type": "string", "description": "Sliding window for date filter (e.g. 15m, 2h). Resources updated in this window are requested." },
            "since": { "type": "string", "description": "Alias for poll_range" },
            "date_param": { "type": "string", "description": "FHIR search param for range (default _lastUpdated). Use date, onset-date, recorded-date, etc. for resource-specific params." },
            "resources": { "type": "array", "items": { "type": "string" }, "description": "Resource types to poll (e.g. Patient, Observation)" },
            "search_queries": { "type": "array", "items": { "type": "string" }, "description": "Search URLs relative to base (e.g. Patient?_count=100)" },
            "version": { "type": "string", "enum": ["R4", "R4B"] },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["base_url"]
        },
        "fhir_subscription": {
          "type": "object",
          "description": "FHIR R4B Subscription source. rest-hook: receive POST notifications. websocket: connect to server and receive events with auto-retry on disconnect.",
          "properties": {
            "channel_type": { "type": "string", "enum": ["rest-hook", "websocket"], "description": "rest-hook or websocket" },
            "port": { "type": "integer", "description": "For rest-hook: port to listen on" },
            "path": { "type": "string", "description": "For rest-hook: path (e.g. /fhir/r4b/subscription-notification)" },
            "websocket_url": { "type": "string", "description": "For websocket: full WebSocket URL" },
            "reconnect_backoff": { "type": "string", "description": "For websocket: backoff between reconnects (e.g. 2s)" },
            "max_reconnect_attempts": { "type": "integer", "description": "For websocket: max reconnects (0 = unlimited)" },
            "version": { "type": "string", "enum": ["R4B"] },
            "subscription_id": { "type": "string", "description": "For logging/correlation" },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["channel_type"]
        },
        "ihe": {
          "type": "object",
          "description": "IHE profile listener",
          "properties": {
            "profile": { "type": "string", "description": "IHE profile (e.g., XDS.b, PIX, PDQ)" },
            "port": { "type": "integer" },
            "tls": { "$ref": "#/definitions/tls" },
            "auth": { "$ref": "#/definitions/auth" }
          },
          "required": ["profile", "port"]
        }
      }
    },
    "validator": {
      "type": "object",
      "description": "Message validator configuration",
      "properties": {
        "runtime": { "type": "string", "enum": ["node"], "description": "Script runtime" },
        "entrypoint": { "type": "string", "description": "TypeScript file for validation (e.g., validator.ts)" }
      }
    },
    "transformer": {
      "type": "object",
      "description": "Message transformer configuration",
      "properties": {
        "runtime": { "type": "string", "enum": ["node"], "description": "Script runtime" },
        "entrypoint": { "type": "string", "description": "TypeScript file for transformation (e.g., transformer.ts)" }
      }
    },
    "pipeline": {
      "type": "object",
      "description": "Advanced pipeline configuration (overrides validator/transformer)",
      "properties": {
        "preprocessor": { "type": "string", "description": "Preprocessor script file" },
        "validator": { "type": "string", "description": "Validator script file" },
        "source_filter": { "type": "string", "description": "Source filter script file" },
        "transformer": { "type": "string", "description": "Transformer script file" },
        "postprocessor": { "type": "string", "description": "Postprocessor script file" }
      }
    },
    "destinations": {
      "type": "array",
      "description": "List of destination references (by name) or inline destination configs",
      "items": {
        "oneOf": [
          { "type": "string", "description": "Reference to a named destination in intu.yaml" },
          {
            "type": "object",
            "properties": {
              "name": { "type": "string", "description": "Destination name" },
              "ref": { "type": "string", "description": "Reference to named destination in intu.yaml" },
              "type": { "type": "string", "enum": ["http", "kafka", "tcp", "file", "database", "sftp", "smtp", "channel", "dicom", "jms", "fhir", "direct"] },
              "http": {
                "type": "object",
                "description": "HTTP destination configuration",
                "properties": {
                  "url": { "type": "string", "description": "Target URL" },
                  "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"], "default": "POST" },
                  "headers": { "type": "object", "additionalProperties": { "type": "string" }, "description": "Request headers" },
                  "query_params": { "type": "object", "additionalProperties": { "type": "string" }, "description": "URL query parameters" },
                  "path_params": { "type": "object", "additionalProperties": { "type": "string" }, "description": "URL path parameters (replaces {key} in URL)" },
                  "timeout_ms": { "type": "integer", "description": "Request timeout in milliseconds" },
                  "auth": { "$ref": "#/definitions/auth" },
                  "tls": { "$ref": "#/definitions/tls" }
                },
                "required": ["url"]
              },
              "kafka": {
                "type": "object",
                "description": "Kafka producer destination",
                "properties": {
                  "brokers": { "type": "array", "items": { "type": "string" } },
                  "topic": { "type": "string" },
                  "client_id": { "type": "string" },
                  "auth": { "$ref": "#/definitions/auth" },
                  "tls": { "$ref": "#/definitions/tls" }
                },
                "required": ["topic"]
              },
              "tcp": {
                "type": "object",
                "description": "TCP/MLLP destination",
                "properties": {
                  "host": { "type": "string" },
                  "port": { "type": "integer" },
                  "mode": { "type": "string", "enum": ["raw", "mllp"] },
                  "timeout_ms": { "type": "integer" },
                  "tls": { "$ref": "#/definitions/tls" },
                  "keep_alive": { "type": "boolean" }
                },
                "required": ["host", "port"]
              },
              "file": {
                "type": "object",
                "description": "File destination",
                "properties": {
                  "scheme": { "type": "string", "enum": ["local", "ftp", "s3", "smb"] },
                  "directory": { "type": "string" },
                  "filename_pattern": { "type": "string", "description": "Filename template (supports {{channelId}}, {{messageId}}, {{correlationId}}, {{timestamp}})" },
                  "sftp": {
                    "type": "object",
                    "properties": {
                      "host": { "type": "string" },
                      "port": { "type": "integer" },
                      "auth": { "$ref": "#/definitions/auth" }
                    }
                  }
                }
              },
              "sftp": {
                "type": "object",
                "description": "SFTP destination",
                "properties": {
                  "host": { "type": "string" },
                  "port": { "type": "integer", "default": 22 },
                  "directory": { "type": "string" },
                  "filename_pattern": { "type": "string" },
                  "auth": { "$ref": "#/definitions/auth" }
                },
                "required": ["host"]
              },
              "database": {
                "type": "object",
                "description": "Database destination",
                "properties": {
                  "driver": { "type": "string", "enum": ["postgres", "mysql", "mssql", "sqlite"] },
                  "dsn": { "type": "string" },
                  "statement": { "type": "string", "description": "SQL statement with ${field} placeholders" }
                },
                "required": ["driver", "dsn", "statement"]
              },
              "smtp": {
                "type": "object",
                "description": "SMTP email destination",
                "properties": {
                  "host": { "type": "string" },
                  "port": { "type": "integer" },
                  "from": { "type": "string" },
                  "to": { "type": "array", "items": { "type": "string" } },
                  "subject": { "type": "string" },
                  "auth": { "$ref": "#/definitions/auth" },
                  "tls": { "$ref": "#/definitions/tls" }
                },
                "required": ["host", "from", "to"]
              },
              "channel": {
                "type": "object",
                "description": "Route to another intu channel",
                "properties": {
                  "target_channel_id": { "type": "string" }
                },
                "required": ["target_channel_id"]
              },
              "dicom": {
                "type": "object",
                "description": "DICOM C-STORE SCU destination",
                "properties": {
                  "host": { "type": "string" },
                  "port": { "type": "integer", "default": 104 },
                  "ae_title": { "type": "string" },
                  "called_ae_title": { "type": "string" },
                  "timeout_ms": { "type": "integer" },
                  "tls": { "$ref": "#/definitions/tls" }
                },
                "required": ["host"]
              },
              "jms": {
                "type": "object",
                "description": "JMS destination via HTTP/REST bridge",
                "properties": {
                  "provider": { "type": "string", "enum": ["activemq"] },
                  "url": { "type": "string" },
                  "queue": { "type": "string" },
                  "auth": { "$ref": "#/definitions/auth" },
                  "timeout_ms": { "type": "integer" }
                },
                "required": ["url", "queue"]
              },
              "fhir": {
                "type": "object",
                "description": "FHIR REST destination",
                "properties": {
                  "base_url": { "type": "string" },
                  "version": { "type": "string", "enum": ["R4", "STU3"] },
                  "operations": { "type": "array", "items": { "type": "string", "enum": ["create", "update", "delete", "read", "transaction", "batch"] } },
                  "auth": { "$ref": "#/definitions/auth" },
                  "tls": { "$ref": "#/definitions/tls" },
                  "timeout_ms": { "type": "integer" }
                },
                "required": ["base_url"]
              },
              "direct": {
                "type": "object",
                "description": "Direct Secure Messaging destination",
                "properties": {
                  "to": { "type": "string" },
                  "from": { "type": "string" },
                  "certificate": { "type": "string" },
                  "smtp": {
                    "type": "object",
                    "properties": {
                      "host": { "type": "string" },
                      "port": { "type": "integer" }
                    }
                  },
                  "tls": { "$ref": "#/definitions/tls" }
                },
                "required": ["to", "from"]
              },
              "filter": { "type": "string", "description": "Destination-specific filter script" },
              "transformer": { "type": "string", "description": "Destination-specific transformer script" },
              "response_transformer": { "type": "string", "description": "Response transformer script" },
              "queue": {
                "type": "object",
                "properties": {
                  "enabled": { "type": "boolean" },
                  "max_size": { "type": "integer" },
                  "overflow": { "type": "string", "enum": ["drop", "block", "reject"] },
                  "persist": { "type": "boolean" },
                  "threads": { "type": "integer" }
                }
              },
              "retry": { "$ref": "#/definitions/retry" }
            }
          }
        ]
      }
    },
    "logging": {
      "type": "object",
      "description": "Channel-specific logging configuration",
      "properties": {
        "level": { "type": "string", "enum": ["debug", "info", "warn", "error"] },
        "payloads": {
          "type": "object",
          "properties": {
            "source": { "type": "boolean" },
            "transformed": { "type": "boolean" },
            "sent": { "type": "boolean" },
            "response": { "type": "boolean" },
            "filtered": { "type": "boolean" }
          }
        },
        "truncate_at": { "type": "integer", "description": "Truncate payload logs at this many characters" }
      }
    },
    "error_handling": {
      "type": "object",
      "description": "Error handling configuration",
      "properties": {
        "on_error": { "type": "string", "enum": ["stop", "continue", "retry"], "description": "Action on error" },
        "dlq": {
          "type": "object",
          "properties": {
            "destination": { "type": "string", "description": "Dead letter queue destination name" }
          }
        },
        "alert": {
          "type": "object",
          "properties": {
            "destination": { "type": "string", "description": "Alert destination name" }
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "on_deploy": { "type": "string", "description": "Script to run on deploy" },
        "on_undeploy": { "type": "string", "description": "Script to run on undeploy" }
      }
    },
    "message_storage": {
      "type": "object",
      "description": "Per-channel message storage overrides. Overrides the global message_storage settings for this channel.",
      "properties": {
        "enabled": { "type": "boolean", "description": "Enable or disable message storage for this channel" },
        "mode": { "type": "string", "enum": ["none", "status", "full"], "description": "Storage mode override: none (no storage), status (metadata only), full (full payloads)" },
        "stages": { "type": "array", "items": { "type": "string", "enum": ["received", "transformed", "filtered", "sent", "error", "response"] }, "description": "Restrict storage to these pipeline stages only" },
        "content_types": { "type": "array", "items": { "type": "string", "enum": ["source", "transformed", "sent", "response", "error"] }, "description": "Legacy alias for stages" },
        "retention_days": { "type": "integer", "description": "Per-channel retention period in days (overrides global)" }
      }
    },
    "batch": {
      "type": "object",
      "description": "Batch processing configuration",
      "properties": {
        "enabled": { "type": "boolean" },
        "type": { "type": "string", "enum": ["split", "aggregate"] },
        "split_on": { "type": "string", "description": "JSONPath for splitting" },
        "custom_splitter": { "type": "string", "description": "Custom splitter script" },
        "max_batch_size": { "type": "integer" },
        "batch_timeout_ms": { "type": "integer" }
      }
    },
